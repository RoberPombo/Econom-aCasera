{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EconomiaCasera",
  "version": "0.1.0",
  "identifier": "com.economiacasera.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Economía Casera",
        "width": 1000,
        "height": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/RoberPombo/Econom-aCasera/releases/latest/download/latest.json"
      ],
      "pubkey": "RWQZjf8V+aqX4Wg2031Aw6cdox8AeKgOinf2lcFaynQ47KIA9VFzKJt6"
    },
    "sql": {
      "preload": ["sqlite: economiacasera.db"]
    }
  }
}
